# DBomni Server Configuration
# Copy this file to .env and fill in your values

PORT=3001

# NVIDIA NIM API Key
# Get yours for free at https://build.nvidia.com/settings/api-keys
# Prefix is typically "nvapi-"
NVIDIA_API_KEY=nvapi-your_key_here

# MongoDB connection string (optional — falls back to in-memory storage)
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/dbomni
